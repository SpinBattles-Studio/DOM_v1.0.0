{
  "name": "decision-optimization-management",
  "version": "1.0.0",
  "description": "AI-powered Decision Optimization Management desktop application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "package": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64",
    "pack": "electron-packager . --platform=win32 --arch=x64 --out=release --overwrite --icon=public/Image/App-icon.ico"
  },
  "keywords": [
    "decision",
    "optimization",
    "ai",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^33.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "lucide-react": "^0.323.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "remark-gfm": "^4.0.1"
  },
  "build": {
    "appId": "com.dom.app",
    "productName": "Decision Optimization Management",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/Image/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/Image/App-icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/Image/App icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/Image/App icon.png"
    }
  }
}
